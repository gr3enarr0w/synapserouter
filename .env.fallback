# Fallback Proxy Configuration

# Server
PORT=8090

# Optional admin auth for debug/audit/memory endpoints only
# ADMIN_API_KEY=change-me

# Optional: inspect startup readiness at /v1/startup-check

# Database
DB_PATH=~/.mcp/proxy/usage.db

# Ollama Cloud
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_MODEL=llama3.1-70b-cloud

# NanoGPT (your existing subscription)
NANOGPT_API_KEY=your-nanogpt-api-key
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

# Usage Tracking Thresholds
USAGE_WARNING_THRESHOLD=0.80
USAGE_CRITICAL_THRESHOLD=0.95

# Provider Daily Limits (adjust based on your subscriptions)
CLAUDE_CODE_DAILY_LIMIT=500000
CODEX_DAILY_LIMIT=300000
OLLAMA_CLOUD_DAILY_LIMIT=1000000
NANOGPT_MONTHLY_QUOTA=60000000
