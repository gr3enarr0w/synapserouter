#!/usr/bin/expect -f
set timeout 60
log_user 1

spawn env NO_COLOR=1 ./synroute code

expect {
    "synroute>" {}
    timeout { puts "FAIL: prompt never appeared"; exit 1 }
}

send "what is a fibonacci sequence\r"

expect {
    "synroute>" {
        puts "PASS_1: got response to knowledge question"
    }
    timeout { puts "FAIL: no response"; exit 1 }
}

send "/exit\r"
expect eof
puts "Phase 1.2 COMPLETE"
