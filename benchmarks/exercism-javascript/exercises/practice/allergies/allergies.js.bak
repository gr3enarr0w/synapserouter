const ALLERGEN_SCORES = {
  eggs: 1,
  peanuts: 2,
  shellfish: 4,
  strawberries: 8,
  tomatoes: 16,
  chocolate: 32,
  pollen: 64,
  cats: 128,
};

const ALLERGENS = Object.keys(ALLERGEN_SCORES);

export class Allergies {
  constructor(score) {
    this.score = score || 0;
  }

  list() {
    return ALLERGENS.filter((allergen) => (this.score & ALLERGEN_SCORES[allergen]) !== 0);
  }

  allergicTo(allergen) {
    return (this.score & ALLERGEN_SCORES[allergen]) !== 0;
  }
}