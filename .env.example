# Synapse Router Configuration
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# ==========================================
# Profile Selection
# ==========================================
# Choose one: "personal" (Ollama Cloud primary) or "work" (Vertex AI)
ACTIVE_PROFILE=personal

# ==========================================
# Personal Profile — Ollama Cloud
# ==========================================
# Required for personal profile: your Ollama Cloud API key
OLLAMA_API_KEY=your-ollama-api-key-here

# Optional: multiple API keys for concurrent requests (round-robin)
# OLLAMA_API_KEYS=key1,key2,key3

# Optional: model escalation chain
# Format: level0_models|level1_models|level2_models
# Pipe (|) separates escalation levels; comma (,) separates models within a level
# Example: starts with fast models, escalates to larger ones on failure
# OLLAMA_CHAIN=ministral-3:14b,gpt-oss:20b|qwen3-8b|gemma3-27b

# Optional: disable subscription fallback providers entirely
# SUBSCRIPTIONS_DISABLED=true

# ==========================================
# Work Profile — Vertex AI (Google Cloud)
# ==========================================
# Required for work profile. Run: gcloud auth application-default login
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1

# Optional: work profile escalation chain (same format as OLLAMA_CHAIN)
# WORK_CHAIN=claude-haiku|claude-sonnet-4-6,gemini-2.5-flash|claude-opus,gemini-2.5-pro

# Optional: corporate OpenAI-compatible provider
# MODELS_CORP_BASE_URL=https://models.corp.example.com/v1

# ==========================================
# Subscription Providers (Optional Fallback)
# ==========================================
# These are used as fallback when the primary provider (Ollama/Vertex) fails.
# You only need these if SUBSCRIPTIONS_DISABLED is not set to true.

# Provider order (comma-separated, first = highest priority)
# SYNROUTE_SUBSCRIPTION_PROVIDER_ORDER=gemini,openai,anthropic

# Anthropic (Claude)
# SYNROUTE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# SYNROUTE_ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (Codex, GPT)
# SYNROUTE_OPENAI_BASE_URL=https://api.openai.com/v1
# SYNROUTE_OPENAI_API_KEY=your-openai-api-key

# Google Gemini
# SYNROUTE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# SYNROUTE_GEMINI_API_KEY=your-gemini-api-key

# ==========================================
# Server Configuration
# ==========================================
PORT=8090
DB_PATH=~/.mcp/proxy/usage.db

# Timeouts (in seconds)
# OLLAMA_TIMEOUT_SECONDS=120
# VERTEX_TIMEOUT_SECONDS=120
# SYNROUTE_SUBSCRIPTIONS_TIMEOUT_SECONDS=120

# ==========================================
# Search Providers (for web_search tool)
# ==========================================
# Priority (by AIMultiple benchmark): BRAVE > TAVILY > SERPER > EXA > SEARXNG > DuckDuckGo
# Set ONE API key to activate that backend:
# SERPER_API_KEY=your-serper-key              # serper.dev — cheapest ($0.30/1K, Google results)
# BRAVE_API_KEY=BS_your-brave-key             # Brave Search — best quality benchmark score
# EXA_API_KEY=your-exa-key                    # Exa AI — semantic/neural search
# TAVILY_API_KEY=tvly_your-tavily-key         # Tavily — AI-optimized search
# SEARXNG_URL=http://localhost:8888           # SearXNG — self-hosted, no key needed
# (DuckDuckGo is the default fallback — no key required)

# ==========================================
# Agent Configuration
# ==========================================
# Starting conversation tier for code mode
# Personal default: frontier | Work default: mid
# SYNROUTE_CONVERSATION_TIER=frontier

# Per-phase tier overrides (cheap, mid, frontier)
# Defaults: plan=frontier, implement=cheap, self-check=mid, code-review=frontier
# SYNROUTE_PLAN_TIER=frontier
# SYNROUTE_IMPLEMENT_TIER=cheap
# SYNROUTE_CHECK_TIER=mid
# SYNROUTE_REVIEW_TIER=frontier
# SYNROUTE_ACCEPTANCE_TIER=frontier
# SYNROUTE_DEPLOY_TIER=cheap

# Explicit tier assignment for OLLAMA_CHAIN levels (pipe-separated)
# Auto-detected if not set: bottom=cheap, middle=mid, top=frontier
# OLLAMA_CHAIN_TIERS=cheap|cheap|mid|mid|frontier|frontier

# Enable MCP server endpoints on the main HTTP server
# SYNROUTE_MCP_SERVER=false

# ==========================================
# Setup Instructions
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Set ACTIVE_PROFILE to "personal" or "work"
# 3. Fill in the API key(s) for your chosen profile
# 4. Build: go build -o synroute .
# 5. Run: ./synroute
