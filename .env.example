# Synapse Router Configuration

# Fallback provider
NANOGPT_API_KEY=your-nanogpt-api-key-here
NANOGPT_BASE_URL=https://nano-gpt.com
NANOGPT_MONTHLY_QUOTA=60000

# Server Configuration
PORT=8090

# Database Paths
DB_PATH=~/.mcp/proxy/usage.db

# Vector Memory / Embeddings Configuration
# Set OPENAI_API_KEY for semantic search with real embeddings
# If not set, will use fast local hash-based embeddings
# OPENAI_API_KEY=sk-your-openai-key-here

# ==========================================
# Embedded Subscription Providers
# ==========================================
# Synroute loads these providers directly in-process.
SYNROUTE_SUBSCRIPTION_PROVIDER_ORDER=anthropic,openai,gemini
SYNROUTE_SUBSCRIPTIONS_TIMEOUT_SECONDS=120

# Claude Code / Claude-family models via Anthropic API
SYNROUTE_ANTHROPIC_BASE_URL=https://api.anthropic.com
SYNROUTE_ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: session auth token if using browser/auth-cookie based workflows
SYNROUTE_ANTHROPIC_SESSION_TOKEN=

# OpenAI Codex-style models via OpenAI API
SYNROUTE_OPENAI_BASE_URL=https://api.openai.com/v1
SYNROUTE_OPENAI_API_KEY=your-openai-api-key
# Optional: session auth token if using browser/auth-cookie based workflows
SYNROUTE_OPENAI_SESSION_TOKEN=

# Gemini models via Google API
SYNROUTE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SYNROUTE_GEMINI_API_KEY=your-gemini-api-key
# Optional: session auth token if using browser/auth-cookie based workflows
SYNROUTE_GEMINI_SESSION_TOKEN=

# ==========================================
# Search Provider API Keys
# ==========================================
# Used by the search side of the repo, not the synroute core router.
TAVILY_API_KEY=tvly_your_tavily_api_key_here
BRAVE_API_KEY=BS_your_brave_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

# ==========================================
# Setup Instructions
# ==========================================
# 1. Copy this file to .env
# 2. Replace placeholder API keys with actual values
# 3. Configure any subscription provider credentials you actually use
# 4. Start the router: go run .  or ./synroute
